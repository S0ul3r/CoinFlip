# Copy to .env and fill for local development (never commit .env)

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Public HTTPS URLs required for Google Play / App Store listings
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://s0ul3r.github.io/coinflip-legal/privacy.html
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://s0ul3r.github.io/coinflip-legal/delete-account.html

# Deploy Edge Functions with secrets (not in the app; use your real Anthropic key):
# npx supabase secrets set ANTHROPIC_API_KEY=sk-ant-api03-...
# npx supabase secrets set ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# (Do not set SUPABASE_* secrets — those are injected automatically on hosted Edge Functions.)

# --- Optional: local catalog import only (never ship service role in the mobile app) ---
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
